<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>KC Connect</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>KC Connect</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>kcconnect</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>kcconnect</string>
			</array>
		</dict>
	</array>

	<!-- Camera — profile photo upload, chat image capture -->
	<key>NSCameraUsageDescription</key>
	<string>KC Connect uses your camera to take photos for your profile and to share images in chat.</string>

	<!-- Photo library — profile photo selection, chat image sharing, resource uploads -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>KC Connect needs access to your photo library so you can select images for your profile and share them in chat.</string>

	<!-- Photo library add — saving downloaded resources/images -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>KC Connect may save images to your photo library when you download shared content.</string>

	<!-- Microphone — required by image_picker on iOS even if you only capture photos -->
	<key>NSMicrophoneUsageDescription</key>
	<string>KC Connect requires microphone access when capturing photos or videos through the camera.</string>

	<!-- Local network — Supabase realtime and in-app connections on local Wi-Fi -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>KC Connect uses your local network to communicate with our servers for real-time chat and notifications.</string>

	<!-- File access — PDF and document uploads/downloads -->
	<key>NSDocumentsFolderUsageDescription</key>
	<string>KC Connect needs access to your files to upload study resources and documents.</string>
</dict>
</plist>
